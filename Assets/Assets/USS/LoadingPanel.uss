:root {
    position: absolute;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    align-self: center;
    width: 100%;
    height: 100%;
}

.loading-panel {
    transition-duration: 1s;
    align-self: center;
    width: 100%;
    height: 100%;
    position: absolute;
    opacity: 0;
    background-color: rgb(0, 0, 0);
}

.loading-panel-active {
    transition-duration: 2s;
    opacity: 1;
}